{
  "name": "@haiai/haiai",
  "version": "0.4.1",
  "description": "Official Node.js SDK for the HAI agent benchmarking platform",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types/types.d.ts",
        "default": "./dist/esm/types.js"
      },
      "require": {
        "types": "./dist/types/types.d.ts",
        "default": "./dist/cjs/types.js"
      }
    },
    "./jacs-wasm": {
      "import": {
        "types": "./dist/types/jacs-wasm.d.ts",
        "default": "./dist/esm/jacs-wasm.js"
      }
    },
    "./jacs-wasm/worker": {
      "import": {
        "types": "./dist/types/jacs-wasm-worker.d.ts",
        "default": "./dist/esm/jacs-wasm-worker.js"
      }
    }
  },
  "bin": {
    "haiai": "./bin/haiai.cjs"
  },
  "dependencies": {
    "@hai.ai/jacs": "file:../../../wasm/jacsnpm",
    "@jacs/wasm": "file:../../../wasm/jacs-wasm/pkg",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "haiinpm": "0.4.1",
    "ws": "^8.16.0"
  },
  "optionalDependencies": {
    "@haiai/cli-darwin-arm64": "0.4.1",
    "@haiai/cli-darwin-x64": "0.4.1",
    "@haiai/cli-linux-arm64": "0.4.1",
    "@haiai/cli-linux-x64": "0.4.1",
    "@haiai/cli-win32-x64": "0.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3",
    "vitest": "^1.2.0"
  },
  "scripts": {
    "deps:local": "node -e \"const p=require('./package.json');p.dependencies['@hai.ai/jacs']='file:../../../wasm/jacsnpm';p.dependencies['@jacs/wasm']='file:../../../wasm/jacs-wasm/pkg';require('fs').writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "deps:prod": "node -e \"const p=require('./package.json'),d=require('./publish.deps.json');Object.assign(p.dependencies,d);require('fs').writeFileSync('package.json',JSON.stringify(p,null,2)+'\\n')\"",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node ./scripts/write-cjs-package.cjs",
    "smoke:package": "npm run build && node ./scripts/smoke-package.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "HAI.AI",
  "license": "BUSL-1.1",
  "homepage": "https://hai.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/HumanAssisted/haiai.git"
  }
}
