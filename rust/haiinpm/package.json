{
  "name": "haiinpm",
  "version": "0.2.3",
  "description": "Node.js napi-rs binding for HAI SDK",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "binaryName": "haiinpm",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  },
  "scripts": {
    "build": "napi build --release --platform",
    "prepublishOnly": "napi prepublish -t npm"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/HumanAssisted/haiai"
  },
  "files": [
    "index.js",
    "index.d.ts"
  ]
}
