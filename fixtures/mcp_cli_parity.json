    { "mcp_tool": "hai_search_messages", "cli_command": "search-messages" },
    { "mcp_tool": "hai_reply_email", "cli_command": "reply-email" },
    { "mcp_tool": "hai_forward_email", "cli_command": "forward-email" },
    { "mcp_tool": "hai_archive_message", "cli_command": "archive-message" },
    { "mcp_tool": "hai_unarchive_message", "cli_command": "unarchive-message" },
