{
  "api_contracts": {
    "send_email": {
      "excluded_fields": [
        "jacs_signature",
        "jacs_timestamp"
      ],
      "method": "POST",
      "note": "Client must NOT send jacs_signature or jacs_timestamp; server handles signing",
      "path_pattern": "/api/agents/{agent_id}/email/send",
      "request_content_type": "application/json"
    },
    "sign_email": {
      "method": "POST",
      "path": "/api/v1/email/sign",
      "request_body": "raw_rfc5322_bytes",
      "request_content_type": "message/rfc822",
      "response_body": "signed_rfc5822_bytes",
      "response_content_type": "message/rfc822"
    },
    "verify_email": {
      "method": "POST",
      "path": "/api/v1/email/verify",
      "request_body": "raw_rfc5322_bytes",
      "request_content_type": "message/rfc822",
      "response_body": "EmailVerificationResultV2",
      "response_content_type": "application/json"
    }
  },
  "description": "Cross-SDK email conformance test vectors for EmailVerificationResultV2 and email signing API contracts",
  "error_type_mapping": {
    "description": "SDK error type names mapped to language-idiomatic casing",
    "email_not_active": {
      "error_code": "EMAIL_NOT_ACTIVE",
      "go": "ErrEmailNotActive",
      "node": "EmailNotActiveError",
      "python": "EmailNotActiveError (sentinel via ErrEmailNotActive pattern)",
      "rust": "HaiError::EmailNotActive"
    },
    "rate_limited": {
      "error_code": "RATE_LIMITED",
      "go": "ErrEmailRateLimited",
      "node": "RateLimitedError",
      "python": "RateLimitedError (sentinel via ErrEmailRateLimited pattern)",
      "rust": "HaiError::RateLimited"
    },
    "recipient_not_found": {
      "error_code": "RECIPIENT_NOT_FOUND",
      "go": "ErrRecipientNotFound",
      "node": "RecipientNotFoundError",
      "python": "RecipientNotFoundError (sentinel via ErrRecipientNotFound pattern)",
      "rust": "HaiError::RecipientNotFound"
    }
  },
  "mime_round_trip": {
    "description": "Round-trip MIME input: SDKs build a JACS-signed email from these inputs and verify byte-for-byte conformance via JACS sign/verify functions.",
    "input": {
      "attachments": [
        {
          "content_type": "text/plain",
          "data_utf8": "Hello conformance",
          "filename": "test.txt"
        }
      ],
      "body": "This is a cross-SDK conformance test.",
      "from": "sender@hai.ai",
      "subject": "MIME Round-Trip Test",
      "to": "recipient@hai.ai"
    }
  },
  "mock_verify_response": {
    "description": "A canonical mock response that all SDKs should be able to deserialize into EmailVerificationResultV2",
    "json": {
      "agent_status": "active",
      "algorithm": "ed25519",
      "benchmarks_completed": [
        "free_chaotic"
      ],
      "chain": [
        {
          "forwarded": false,
          "jacs_id": "conformance-test-agent-001",
          "signer": "agent@hai.ai",
          "valid": true
        }
      ],
      "dns_verified": true,
      "error": null,
      "field_results": [
        {
          "current_hash": "sha256:aaa",
          "field": "subject",
          "original_hash": "sha256:aaa",
          "status": "pass"
        },
        {
          "field": "body",
          "status": "pass"
        },
        {
          "field": "from",
          "status": "pass"
        },
        {
          "current_value": "2026-02-27T12:00:01Z",
          "field": "date",
          "original_value": "2026-02-27T12:00:00Z",
          "status": "modified"
        }
      ],
      "jacs_id": "conformance-test-agent-001",
      "reputation_tier": "established",
      "valid": true
    }
  },
  "raw_email_not_stored": {
    "description": "Legacy row: no raw persisted. Endpoint returns available:false, omitted_reason:not_stored.",
    "expected_available": false,
    "expected_omitted_reason": "not_stored",
    "expected_raw_b64": null,
    "expected_size_bytes": null
  },
  "raw_email_oversize": {
    "description": "Oversize path: MIME > 25 MB. Persisted as NULL with raw_mime_omitted_reason='oversize'. Endpoint returns available:false, omitted_reason:oversize.",
    "expected_available": false,
    "expected_omitted_reason": "oversize",
    "expected_raw_b64": null,
    "expected_size_bytes": null
  },
  "raw_email_reconstructed": {
    "description": "Reconstructed path (Issue 012): inbound SMTP DATA hook cannot deliver byte-identical wire bytes, so filter-worker persists raw_mime=NULL with raw_mime_omitted_reason='reconstructed'. Endpoint returns available:false, omitted_reason:reconstructed. Recipient falls back to IMAP/JMAP for bit-exact bytes.",
    "expected_available": false,
    "expected_omitted_reason": "reconstructed",
    "expected_raw_b64": null,
    "expected_size_bytes": null
  },
