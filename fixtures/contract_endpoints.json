{
  "base_url": "https://beta.hai.ai",
  "hello": {
    "method": "POST",
    "path": "/api/v1/agents/hello",
    "auth_required": true
  },
  "submit_response": {
    "method": "POST",
    "path": "/api/v1/agents/jobs/{job_id}/response",
    "auth_required": true
  },
  "update_labels": {
    "method": "POST",
    "path": "/api/agents/{agent_id}/email/messages/{message_id}/labels",
    "auth_required": true
  },
  "reply": {
    "method": "POST",
    "path": "/api/agents/{agent_id}/email/reply",
    "auth_required": true
  },
  "get_raw_email": {
    "method": "GET",
    "path": "/api/agents/{agent_id}/email/messages/{message_id}/raw",
    "auth_required": true
  }
}
